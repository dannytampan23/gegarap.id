# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION env reference (project "gegarap"). Set these in Vercel → Settings →
# Environment Variables (Production). Do NOT set any *_EMULATOR_HOST or
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR in production.
#
# NEXT_PUBLIC_* values are public by design (they ship to the browser, access is
# governed by Firestore security rules). Everything else here is SECRET.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web (public) — from console → Project settings → your web app.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAXDLfO3XFwwy1ST4n4DAWktrA5ftNhz5s
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gegarap.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gegarap

# Firebase Admin (server, SECRET) — console → Project settings → Service accounts
# → "Generate new private key". Paste the WHOLE JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Public site URL (used by auth redirects, midtrans callbacks, emails).
APP_URL=https://your-domain.com

# Support contact (public, REQUIRED). The production build HARD-FAILS if any of
# these is missing or still a placeholder — see scripts/check-env.mjs.
# WA = international format, no + and no leading 0.
NEXT_PUBLIC_WA_SUPPORT=628xxxxxxxxxx
NEXT_PUBLIC_EMAIL_SUPPORT=halo@your-domain.com
NEXT_PUBLIC_EMAIL_PRIVACY=privacy@your-domain.com

# Postgres (SECRET) — your managed cloud DB (Neon/Supabase).
DATABASE_URL=

# Midtrans (SECRET) — payment gateway.
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true

# Payouts fail closed in production. Use "disabled" until Iris is configured.
DISBURSEMENT_PROVIDER=disabled
MIDTRANS_IRIS_API_KEY=

# Vercel Cron uses this secret. GitHub maintenance uses short-lived OIDC.
CRON_SECRET=

# Optional shared cache for public endpoints. Sensitive mutations use Postgres.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional external paging endpoint for high-severity alerts.
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_TOKEN=

# Email receipts (Resend, SECRET). EMAIL_FROM must be a verified sender on the
# Resend domain. If EMAIL_API_KEY is empty the receipt email is skipped (logged).
EMAIL_FROM=gegarap.id <noreply@gegarap.id>
EMAIL_API_KEY=

# Anthropic (Claude) — AI assistant (SECRET). If empty, the assistant uses a
# deterministic RAG-grounded fallback instead of calling the model.
ANTHROPIC_API_KEY=

# Supabase (KTP storage).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET=

# (Programmatic WhatsApp messaging removed — no OTP, no automated notifications.
# The WhatsApp number is a stored contact only, surfaced as a wa.me click-to-chat
# link. No gateway/token/device required.)
