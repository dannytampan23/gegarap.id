generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ─────────────────────────────────────────────────────────────────
// Domain identity mirror of the Firebase Auth user (User.id == Firebase uid).
// Login/credentials live in Firebase; this row is the authoritative source for
// `role` and the canonical WhatsApp number `phone` (format 628xxxxxxxxxx) used
// for booking contact + notifications. `phoneNumber` is a legacy free-form field.
model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  phone           String?          @unique
  phoneNumber     String?
  role            String           @default("CUSTOMER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  jobsAsCustomer  Job[]            @relation("CustomerJobs")
  reviews         Review[]
  payments        Payment[]        @relation("CustomerPayments")
  providerProfile ProviderProfile?
  chatSessions    ChatSession[]
}

// ─── CHAT SESSION ─────────────────────────────────────────────────────────
// Persisted AI assistant conversation (System 4). `messages` is an append-only
// JSON array of { role, content } turns. `userId` is optional so anonymous
// (pre-login) visitors can still use the assistant; their history is keyed by
// the client-supplied sessionId on the row id.
model ChatSession {
  id        String   @id @default(uuid())
  userId    String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ─── ARTICLE (programmatic SEO content engine) ────────────────────────────
// AI-generated home-services SEO article (System 5). Produced by the content
// pipeline (lib/ai/content): topic → SEO structuring → generation → self-audit →
// dedup → grounded internal links. Persisted as DRAFT; an admin reviews and
// PUBLISHES. `slug` is the public URL key (/artikel/<slug>). Money/PII never live
// here — these are public marketing pages.
model Article {
  id              String   @id @default(uuid())
  slug            String   @unique // URL key, kebab-case, derived from title
  title           String // SEO title, ≤ 60 chars
  metaDescription String // ≤ 155 chars
  contentMarkdown String // body in Markdown (controlled subset)
  faq             Json     @default("[]") // [{ q, a }]
  internalLinks   Json     @default("[]") // [{ label, href }] — grounded to real routes
  category        String // matches ProviderProfile.category (drives the CTA + links)
  location        String // kecamatan / area string for local relevance
  primaryKeyword  String
  keywords        String[] @default([]) // secondary/semantic keywords
  intent          String   @default("informational") // informational | transactional

  // Self-audit scores (1–10 each) from the quality gate, kept for ops/analytics.
  scoreSeo         Int @default(0)
  scoreReadability Int @default(0)
  scoreValue       Int @default(0)
  scoreTrust       Int @default(0)
  scoreConversion  Int @default(0)
  scoreTotal       Int @default(0)

  // Dedup bookkeeping vs existing titles (no embeddings — token/trigram sim).
  similarityScore Float   @default(0)
  newAngle        String?

  status      String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  generatedBy String    @default("fallback") // "claude-sonnet-4-6" | "fallback"
  authorId    String? // admin User.id who generated it (null = system)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

// ─── OUTBOX MESSAGE ───────────────────────────────────────────────────────
// Transactional outbox for outbound notifications. Request handlers ENQUEUE a
// row (a fast local INSERT) instead of awaiting a slow external WhatsApp call,
// so a gateway hiccup never blocks or fails the business transaction. A cron
// dispatcher (`/api/cron/dispatch-outbox`) delivers PENDING rows and retries
// failures up to OUTBOX_MAX_ATTEMPTS before parking them as FAILED.
model OutboxMessage {
  id        String    @id @default(uuid())
  channel   String    @default("WHATSAPP") // WHATSAPP (future: EMAIL, PUSH)
  toAddress String // recipient — WA number 628xxxxxxxxxx
  body      String // rendered message text
  status    String    @default("PENDING") // PENDING | SENT | FAILED
  attempts  Int       @default(0)
  lastError String?
  dedupeKey String?   @unique // optional idempotency guard for retried transitions
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
}

// ─── PROVIDER PROFILE ─────────────────────────────────────────────────────
model ProviderProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  category      String // kategori utama (= categories[0], dipertahankan utk kueri lama)
  categories    String[] @default([]) // semua keahlian (multi-select onboarding KYC)
  districts     String[] @default([]) // kecamatan operasional, maks 5
  dailyRate     Int // tarif/hari dalam Rupiah utuh (integer minor-unit)
  goPayNumber   String?
  payoutMethod  String? // "bank" | "gopay" | "ovo" | "dana"
  payoutDetails Json? // { bankName, accountNumber, accountName } atau { phone }
  isVerified    Boolean  @default(false)
  available     Boolean  @default(true)
  bio           String?
  avatarUrl     String?
  ktpImageUrl   String? // PATH objek KTP di private bucket (bukan URL publik)

  // ─ KYC onboarding (wizard 5 langkah) ─ semua disimpan server-side saja, tidak
  // pernah masuk PROVIDER_PUBLIC_SELECT. `nik` & dokumen = PII sensitif.
  nik             String? // 16 digit; PII — JANGAN expose ke klien publik
  nikHash         String?
  nikLast4        String?
  identityStatus  String    @default("UNVERIFIED") // UNVERIFIED | PHONE_VERIFIED | IDENTITY_SUBMITTED | MANUALLY_VERIFIED | REJECTED | SUSPENDED
  identitySubmittedAt DateTime?
  identityVerifiedAt DateTime?
  identityRejectedReason String?
  verifiedByAdminId String?
  phoneVerifiedAt DateTime?
  experienceYears Int? // lama pengalaman (tahun)
  serviceRadiusKm Int? // radius layanan dari titik provider (km)
  faceImageUrl    String? // PATH foto wajah di private bucket (verifikasi liveness KYC)
  certificateUrl  String? // PATH sertifikat opsional di private bucket
  payoutStatus    String    @default("UNVERIFIED") // UNVERIFIED | SUBMITTED | VERIFIED | REJECTED
  payoutVerifiedAt DateTime?

  // KYC review state
  kycStatus    String    @default("PENDING") // PENDING | APPROVED | REJECTED
  kycReason    String? // alasan penolakan (jika REJECTED)
  kycReviewedAt DateTime?
  kycReviewedById String? // User.id admin yang meninjau

  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  completedJobs Int      @default(0)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobsAsProvider Job[]     @relation("ProviderJobs")
  reviews        Review[]
  payments       Payment[] @relation("ProviderPayments")
  payouts        Payout[]
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isVerified])
  @@index([kycStatus])
  @@index([identityStatus])
  @@index([nikHash])
}

// ─── JOB (booking) ─────────────────────────────────────────────────────────
// The booking entity. Financials are snapshotted at creation time.
model Job {
  id                String   @id @default(uuid())
  customerId        String
  providerProfileId String
  status            String   @default("PENDING") // PENDING|CONFIRMED|IN_PROGRESS|COMPLETED|CANCELLED
  description       String?
  estimatedDays     Int
  customerAddress   String
  customerWaNumber  String
  district          String?
  scheduledDate     DateTime?
  timeSlot          String? // "pagi" | "siang" | "sore"
  notes             String?
  isConsentGiven    Boolean  @default(true)

  // Finansial — semua dalam Rupiah utuh (integer minor-unit, tanpa desimal)
  dailyRate          Int @default(0) // snapshot tarif saat booking
  totalFee           Int // subtotal = dailyRate * estimatedDays
  dpAmount           Int @default(0) // DP yang dibayar
  platformCommission Int @default(0) // platform fee (dari FeeConfig)
  providerPayout     Int @default(0) // totalFee - platformCommission

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer User            @relation("CustomerJobs", fields: [customerId], references: [id])
  provider ProviderProfile @relation("ProviderJobs", fields: [providerProfileId], references: [id])
  payment  Payment?
  review   Review?

  @@index([customerId])
  @@index([providerProfileId])
  @@index([status])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────
// The financial source of truth for a booking. Money fields are integer Rupiah
// snapshots taken at creation (fee rules can change later — this never does).
// State transitions are backend-only and every one is logged to PaymentEvent.
model Payment {
  id     String @id @default(uuid())
  jobId  String @unique
  amount Int // nilai DP yang ditagih (untuk Snap charge pertama)
  type   String @default("DP") // DP | FULL
  // Lifecycle (Bagian 3):
  // DRAFT|PENDING|PAID|HELD|RELEASED|REFUND_REQUESTED|REFUNDED|REFUND_REJECTED|DISPUTED|EXPIRED|FAILED
  status String @default("PENDING")

  // Denormalised principals — indexed for admin/dashboard queries.
  customerId        String?
  providerProfileId String?

  // Financial snapshot (Bagian 6). round_down sisa pembulatan jadi milik platform.
  dpAmount        Int @default(0) // bagian yang dibayar di muka
  remainingAmount Int @default(0) // sisa yang ditagih saat job selesai
  platformFee     Int @default(0) // fee platform (snapshot)
  providerAmount  Int @default(0) // amount - platformFee

  // Aturan fee yang dipakai saat transaksi ini (snapshot reference, BUKAN live).
  feeConfigId String?
  campaignId  String?

  // Gateway
  paymentGateway      String  @default("MIDTRANS") // MIDTRANS | XENDIT
  idempotencyKey      String? @unique // unik per percobaan pembayaran
  midtransTrxId       String? @unique
  midtransOrderId     String? @unique // externalId — format: GGR-{jobId}-{timestamp}
  midtransToken       String? // Snap token
  midtransPaymentType String? // gopay, bank_transfer, dll
  midtransVaNumber    String? // virtual account number jika ada
  paidAt              DateTime?

  // Disbursement bookkeeping (canonical record is Payout; these are kept for
  // backward-compat with the existing complete flow).
  disbursedAt        DateTime?
  disbursedAmount    Int?
  platformFeeCharged Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job            Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  customer       User?           @relation("CustomerPayments", fields: [customerId], references: [id])
  provider       ProviderProfile? @relation("ProviderPayments", fields: [providerProfileId], references: [id])
  events         PaymentEvent[]
  refundRequests RefundRequest[]
  payouts        Payout[]

  @@index([customerId])
  @@index([providerProfileId])
  @@index([status])
}

// ─── PAYMENT EVENT ─────────────────────────────────────────────────────────
// Append-only audit log of every payment state transition. Must be able to
// reconstruct a transaction's full history. Never updated or deleted.
model PaymentEvent {
  id                String   @id @default(uuid())
  paymentId         String
  fromStatus        String?
  toStatus          String
  triggeredBy       String // SYSTEM | WEBHOOK | <userId of admin/customer/provider>
  reason            String?
  rawWebhookPayload Json? // forensic copy of the gateway payload, if any
  createdAt         DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
}

// ─── REFUND REQUEST ────────────────────────────────────────────────────────
model RefundRequest {
  id             String   @id @default(uuid())
  paymentId      String
  requestedById  String // User.id (customer/admin)
  reason         String
  evidenceUrls   String[] @default([])
  type           String // FULL | PARTIAL
  amount         Int? // wajib untuk PARTIAL
  status         String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED
  resolvedById   String?
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
}

// ─── PAYOUT ────────────────────────────────────────────────────────────────
// One disbursement attempt to a provider. Mockable via IDisbursementProvider.
model Payout {
  id                     String   @id @default(uuid())
  providerProfileId      String
  paymentId              String
  amount                 Int
  status                 String   @default("SCHEDULED") // SCHEDULED | PROCESSING | SUCCESS | FAILED
  disbursementExternalId String?
  failureReason          String?
  scheduledAt            DateTime @default(now())
  executedAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  payment  Payment         @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
  @@index([paymentId])
  @@index([status])
}

// ─── FEE CONFIG ────────────────────────────────────────────────────────────
// Configurable fee/DP rules per service category. NEVER hardcode fees in code —
// a Payment snapshots the FeeConfig id it used. `category = "DEFAULT"` is the
// fallback when no category-specific row is effective.
model FeeConfig {
  id                   String    @id @default(uuid())
  category             String // matches ProviderProfile.category, or "DEFAULT"
  platformFeePercent   Float // mis. 10 = 10%
  dpPercent            Float // mis. 30 = 30%
  minDpThresholdAmount Int       @default(0) // subtotal di atas ini → DP dinaikkan
  highValueDpPercent   Float     @default(50) // DP% untuk job di atas threshold
  effectiveFrom        DateTime  @default(now())
  effectiveTo          DateTime?
  createdAt            DateTime  @default(now())

  @@index([category])
}

// ─── CAMPAIGN ──────────────────────────────────────────────────────────────
// Promo that overrides ONLY platformFee (never dpAmount/providerAmount — a
// promo must never cost the provider).
model Campaign {
  id                 String   @id @default(uuid())
  name               String
  feeOverridePercent Float // mis. 0 = promo gratis biaya admin
  eligibleCategories String[] @default([]) // kosong = semua kategori
  startDate          DateTime
  endDate            DateTime
  usageLimit         Int?
  usedCount          Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([active])
}

// ─── FRAUD FLAG ────────────────────────────────────────────────────────────
// Flags NEVER auto-block an account — an admin decides (avoids false positives
// hurting honest users).
model FraudFlag {
  id           String    @id @default(uuid())
  userId       String
  type         String // VELOCITY | REFUND_ABUSE | DEVICE_MISMATCH | MANUAL
  severity     String    @default("LOW") // LOW | MEDIUM | HIGH
  note         String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?
  resolvedById String?

  @@index([userId])
  @@index([type])
}

// ─── DEVICE EVENT ──────────────────────────────────────────────────────────
// Lightweight (device, account) observation log feeding the device-fingerprint
// fraud check (Bagian 8). `deviceId` is a hash (x-device-id header or IP+UA), so
// no raw PII is stored. Append-only; old rows can be pruned on a schedule.
model DeviceEvent {
  id        String   @id @default(uuid())
  deviceId  String // sha256 hash, 32 chars
  userId    String
  createdAt DateTime @default(now())

  @@index([deviceId, createdAt])
  @@index([userId])
}

// ─── WEBHOOK EVENT ─────────────────────────────────────────────────────────
// Idempotency ledger for inbound gateway notifications. The unique constraint
// makes duplicate retries a no-op (insert fails → we ack 200 without reprocessing).
model WebhookEvent {
  id             String   @id @default(uuid())
  gateway        String   @default("MIDTRANS")
  externalId     String // order_id
  eventType      String // transaction_status
  signatureValid Boolean
  rawPayload     Json
  processedAt    DateTime @default(now())

  @@unique([gateway, externalId, eventType])
  @@index([externalId])
}

// ─── REVIEW ───────────────────────────────────────────────────────────────
model Review {
  id                String   @id @default(uuid())
  jobId             String   @unique
  userId            String
  providerProfileId String
  rating            Int // 1–5
  comment           String?
  createdAt         DateTime @default(now())

  job      Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id])
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
}

// ─── CONTACT REQUEST (dari form /help) ────────────────────────────────────
model ContactRequest {
  id        String   @id @default(uuid())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────
// Append-only trail of sensitive admin/financial actions: who did what, to
// which entity, and when. Drives "who approved KYC / who triggered a refund".
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String? // User.id of the actor (null = system/automated)
  action     String // e.g. KYC_APPROVE, KYC_REJECT, REFUND_TRIGGERED
  targetType String // e.g. ProviderProfile, Payment, Job
  targetId   String
  metadata   Json? // arbitrary context (reason, amounts, before/after)
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
}
