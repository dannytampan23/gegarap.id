generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USER ─────────────────────────────────────────────────────────────────
// Auth identity. Customers and providers are both Users; a provider also has a
// linked ProviderProfile. `phone` is the canonical WhatsApp OTP login identity
// (format 628xxxxxxxxxx); `phoneNumber` is the legacy free-form contact field.
model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  phone           String?          @unique
  passwordHash    String?
  phoneNumber     String?
  role            String           @default("CUSTOMER")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  jobsAsCustomer  Job[]            @relation("CustomerJobs")
  reviews         Review[]
  providerProfile ProviderProfile?
}

// ─── OTP TOKEN ────────────────────────────────────────────────────────────
model OtpToken {
  id        String   @id @default(uuid())
  phone     String // format kanonik: 628xxxxxxxxxx
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0) // maks 5 percobaan salah lalu invalidasi
  createdAt DateTime @default(now())

  @@index([phone])
}

// ─── PROVIDER PROFILE ─────────────────────────────────────────────────────
model ProviderProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  category      String
  districts     String[] @default([]) // kecamatan operasional, maks 5
  dailyRate     Float
  goPayNumber   String?
  payoutMethod  String? // "bank" | "gopay" | "ovo" | "dana"
  payoutDetails Json? // { bankName, accountNumber, accountName } atau { phone }
  isVerified    Boolean  @default(false)
  available     Boolean  @default(true)
  bio           String?
  avatarUrl     String?
  ktpImageUrl   String? // PATH objek KTP di private bucket (bukan URL publik)

  // KYC review state
  kycStatus    String    @default("PENDING") // PENDING | APPROVED | REJECTED
  kycReason    String? // alasan penolakan (jika REJECTED)
  kycReviewedAt DateTime?
  kycReviewedById String? // User.id admin yang meninjau

  rating        Float    @default(0)
  ratingCount   Int      @default(0)
  completedJobs Int      @default(0)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  jobsAsProvider Job[]    @relation("ProviderJobs")
  reviews        Review[]
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isVerified])
  @@index([kycStatus])
}

// ─── JOB (booking) ─────────────────────────────────────────────────────────
// The booking entity. Financials are snapshotted at creation time.
model Job {
  id                String   @id @default(uuid())
  customerId        String
  providerProfileId String
  status            String   @default("PENDING") // PENDING|CONFIRMED|IN_PROGRESS|COMPLETED|CANCELLED
  description       String?
  estimatedDays     Int
  customerAddress   String
  customerWaNumber  String
  district          String?
  scheduledDate     DateTime?
  timeSlot          String? // "pagi" | "siang" | "sore"
  notes             String?
  isConsentGiven    Boolean  @default(true)

  // Finansial — semua dalam Rupiah
  dailyRate          Float @default(0) // snapshot tarif saat booking
  totalFee           Float // subtotal = dailyRate * estimatedDays
  dpAmount           Float @default(0) // DP yang dibayar (min Rp 20.000)
  platformCommission Float // platform fee flat Rp 20.000
  providerPayout     Float // totalFee - platformCommission

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer User            @relation("CustomerJobs", fields: [customerId], references: [id])
  provider ProviderProfile @relation("ProviderJobs", fields: [providerProfileId], references: [id])
  payment  Payment?
  review   Review?

  @@index([customerId])
  @@index([providerProfileId])
  @@index([status])
}

// ─── PAYMENT ──────────────────────────────────────────────────────────────
model Payment {
  id     String @id @default(uuid())
  jobId  String @unique
  amount Float // jumlah DP yang dibayar
  type   String @default("DP")
  status String @default("PENDING") // PENDING|PAID|DISBURSED|REFUNDED|FAILED

  // Midtrans
  midtransTrxId       String?   @unique
  midtransOrderId     String?   @unique // format: GGR-{jobId}-{timestamp}
  midtransToken       String? // Snap token
  midtransPaymentType String? // gopay, bank_transfer, dll
  midtransVaNumber    String? // virtual account number jika ada
  paidAt              DateTime?

  // Disbursement (setelah customer klik Selesai)
  disbursedAt        DateTime?
  disbursedAmount    Float?
  platformFeeCharged Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ─── REVIEW ───────────────────────────────────────────────────────────────
model Review {
  id                String   @id @default(uuid())
  jobId             String   @unique
  userId            String
  providerProfileId String
  rating            Int // 1–5
  comment           String?
  createdAt         DateTime @default(now())

  job      Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id])
  provider ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
}

// ─── CONTACT REQUEST (dari form /help) ────────────────────────────────────
model ContactRequest {
  id        String   @id @default(uuid())
  name      String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────
// Append-only trail of sensitive admin/financial actions: who did what, to
// which entity, and when. Drives "who approved KYC / who triggered a refund".
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String? // User.id of the actor (null = system/automated)
  action     String // e.g. KYC_APPROVE, KYC_REJECT, REFUND_TRIGGERED
  targetType String // e.g. ProviderProfile, Payment, Job
  targetId   String
  metadata   Json? // arbitrary context (reason, amounts, before/after)
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
}
