{
  "name": "gegarap-id",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "@opentelemetry/core": "2.9.0",
    "jose": "^5.9.6",
    "postcss": "8.5.15",
    "uuid": "11.1.1"
  },
  "scripts": {
    "dev": "concurrently -n emulators,next -c magenta,cyan \"npm:dev:emulators\" \"next dev\"",
    "dev:emulators": "node scripts/dev-emulators.mjs",
    "dev:next": "next dev",
    "prebuild": "node scripts/check-env.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/auth.spec.ts e2e/homepage.spec.ts e2e/production-smoke.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "vitest run && playwright test",
    "audit:deps": "npm audit --audit-level=moderate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:vercel": "node scripts/migrate-vercel.mjs",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "seed": "tsx prisma/seed.ts",
    "setup": "prisma db push && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.67.0",
    "@supabase/supabase-js": "^2.108.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "immer": "^11.1.8",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "midtrans-client": "^1.4.3",
    "next": "^16.2.10",
    "pg": "^8.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.16.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.169.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.4",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "firebase-tools": "^15.22.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "8.5.15",
    "prettier": "^3.3.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.1",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^4.0.0"
  }
}
