{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "git": {
    "deploymentEnabled": {
      "main": false
    }
  },
  "crons": [
    { "path": "/api/cron/auto-cancel", "schedule": "0 1 * * *" },
    { "path": "/api/cron/reconcile", "schedule": "0 2 * * *" },
    { "path": "/api/cron/auto-release", "schedule": "0 3 * * *" },
    { "path": "/api/cron/dispatch-outbox", "schedule": "0 4 * * *" }
  ]
}
